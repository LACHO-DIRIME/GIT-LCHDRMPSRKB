+====================================================================
+PROMPT L-04 — Test suite gramática extendida
+====================================================================
+ARCHIVO: /media/Personal/PLANERAI/DIRIME/IMV/tests/test_imv.py
+AGREGAR clase TestGrammarExtended al final del archivo existente.
+
+6 tests nuevos:
+
+  def test_9_bibliotecas_validan(self):
+      libs = ['TRUST','SOCIAL','CRYPTO','WORK','SAMU',
+              'ACTIVITY','GATE','STACKING','METHOD']
+      for lib in libs:
+          r = validate(f'{lib} FOUNDATION =><= .. verifica .. obj --[As de Guía] [term]')
+          self.assertTrue(r.valid, f'{lib} debería ser VALID')
+
+  def test_verbo_natural_no_warning(self):
+      r = validate('TRUST FOUNDATION =><= .. verifica .. scope_activo --[As de Guía] [term]')
+      self.assertTrue(r.valid)
+      self.assertFalse(any('verbo' in w.lower() for w in r.warnings))
+
+  def test_verbo_mismatch_warning(self):
+      r = validate('TRUST FOUNDATION =><= .. lanza .. scope_activo --[As de Guía] [term]')
+      self.assertTrue(r.valid)
+      self.assertTrue(any('verbo' in w.lower() for w in r.warnings))
+
+  def test_sujeto_canonico_no_warning(self):
+      r = validate('WORK {actuator} =><= .. materializa .. tarea --[As de Guía] [term]')
+      self.assertTrue(r.valid)
+      self.assertFalse(any('sujeto' in w.lower() for w in r.warnings))
+
+  def test_sujeto_mismatch_warning(self):
+      r = validate('WORK {motor} =><= .. ejecuta .. tarea --[As de Guía] [term]')
+      self.assertTrue(r.valid)
+      self.assertTrue(any('sujeto' in w.lower() for w in r.warnings))
+
+  def test_term_ausente_invalida(self):
+      r = validate('TRUST FOUNDATION =><= .. verifica .. scope --[As de Guía]')
+      self.assertFalse(r.valid)
+
+====================================================================
+VERIFICAR (sin pytest):
+  cd /media/Personal/PLANERAI/DIRIME/IMV
+  python3 tests/test_imv.py
+
+Esperado: todos los tests pasan incluyendo los 6 nuevos
+Alias opcional en ~/.bashrc:
+  alias dirime-tests='cd /media/Personal/PLANERAI/DIRIME/IMV && python3 tests/test_imv.py'
+====================================================================
+
