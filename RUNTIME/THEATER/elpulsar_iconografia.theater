## HEADCAT — DIRECTOR DE SALIDA WU
headcat_icono {
  SOCIAL {headcat} =><= .. gobierna .. salida_WU_soberana --[As de Guía] [term]
  SOCIAL {headcat} =><= .. audita .. estado_sistema_activo --[Ballestrinque] [term]
  -- "los ojos del headcat son el [ku-chat] activo"
  -- "mirando hacia la pantalla del operador, no hacia afuera"
}

## FLYBOT — AGENTE DE EJECUCIÓN
flybot_icono {
  WORK {flybot} =><= .. ejecuta .. WU_validado_en_hardware --[As de Guía] [term]
  -- "LACHO → HEADCAT → FLYBOT → HARDWARE"
  -- "INTENCIÓN → VALIDACIÓN → EJECUCIÓN → ACCIÓN"
  -- Ψ(T) visible en el pecho · Nudo As de Guía en estela
}

## SAMU @ — HILO CONECTOR
samu_iconos {
  -- "@" aparece en: zipper · headcat · doorman-mobile
  -- es el auditor que dice: "esto fue escuchado antes de ser emitido"
  SAMU @ =><= .. conecta .. iconos_supervision_activos --[Ballestrinque] [term]
}

## BALLPAPER — SUPERFICIE GRÁFICA
ballpaper {
  -- UNICODE estándar: ①–⑳ ㉑–㊿ ● ○ ╔ ╗ ╠ ╣ ╚ ╝
  -- función: ballpaper_render() en interface/chat.py
  -- muestra: LACHO_SCORE · Scalar S · TX · Cristales
  METHOD <stat_onto> =><= .. renderiza .. ballpaper_estado_vivo --[As de Guía] [term]
}

[term] :: activo · [seal of secrecy] :: activo
