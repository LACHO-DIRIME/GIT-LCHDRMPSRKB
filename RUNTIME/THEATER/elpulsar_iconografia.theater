## GATE — CICLO CRONOTÓPICO (3 puertas)
gate_iconos {
  door_morning  :: H1→H5   :: ignicion_dia   :: human_out_mañana
  zipper_noon   :: H5→H56  :: apertura_KU    :: SAMU_@_escucha
  door_afternoon:: H56→H6  :: WU_materializado :: nudo_ocho_sellado
  -- "las tres puertas narran el ciclo completo de una sesión LACHO"
}

## STACKING — 8 PILARES VISUALES
stacking_iconos {
  rocking_chair_headcat :: H57+H52 :: auditoria_pasiva   :: ku_chat_activo
  scheduler             :: H1      :: mapa_intencion     :: bagua_temporal
  tap_drip              :: H29     :: flujo_calibrado    :: gradiente_descendente
  papernote             :: H2      :: registro_pasivo    :: behavioral_rag
  rabbit_eggs           :: H64     :: crecimiento_ramificado :: algoritmo_conejo
