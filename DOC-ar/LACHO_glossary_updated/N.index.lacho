## NEWLINE [N1]
# Clase: token · Gramática ANTLR
# Token de salto de línea en la gramática LACHO.
# NEWLINE ::= "\n" | "\r\n"
# COMMENT_LINE ::= COMMENT_OPEN [^\n]* NEWLINE
# Ver: COMMENT_LINE · DECL_LINE · BNF

## NDJSON [N1]
# Clase: formato · Sistema de telemetría · Behavioral RAG
# Newline-Delimited JSON. Una entrada por línea.
# "Formato NDJSON — una entrada por línea. Legible por Behavioral RAG."
# pulse.registry en NDJSON: cada evento lleva [RAG: KEYWORD :: estado :: $dia_hora]
# Ver: JSON · BEHAVIORAL_RAG · APPEND_ONLY_LOG

## NULL [N1]
# Clase: tipo de dato · ledger.py · SQL
# Valor nulo. En sovereign.db: NOT NULL obligatorio en campos críticos.
# type TEXT NOT NULL → TransactionType enum value
# timestamp REAL NOT NULL → time.time() Unix epoch
# Ver: ledger.py · sovereign.db · IDENTIFIER

