## BIBLIOTECA [N1]
# Clase: órgano del lenguaje · Nivel: constitucional
# En LACHO una biblioteca no es "un conjunto de funciones":
# es un órgano con jurisdicción propia.
# Las nueve bibliotecas del sistema:
#   TRUST (imperativo) · SOCIAL (declarativo) · CRYPTO (funcional)
#   STACKING (orientado a objetos) · GATE (de script)
#   WORK (bajo nivel) · SAMU (alto nivel)
#   METHOD (operadores) · ACTIVITY (movimiento/ciclos)
# Fuente canónica: BIBLIOTECAS_MADRE_LACHO.txt

## BILATERAL [N1]
# Clase: operador · Gramática LACHO
# Operación que afecta ambos lados simultáneamente.
# BILATERAL ::= "<>"
# El operador BILATERAL <> conecta el Vortex con el Stacking
# principal para transferencia de Haberes validados.

## BNF [N1]
# Clase: notación · Gramática formal LACHO
# Backus-Naur Form extendida (EBNF) propia del sistema.
# ;;; — Notación BNF extendida (EBNF) propia del sistema
# 5.3 Gramática BNF Simplificada: especificación de la sintaxis LACHO.
# Ver: ANTLR · AST · BOOLEAN · BILATERAL

## BOOLEAN [N1]
# Clase: tipo de dato · Gramática ANTLR
# Tipo de valor booleano en la gramática JSON/LACHO.
# JSON_VALUE ::= STRING | NUMBER | BOOLEAN | JSON_OBJECT

## BROADCAST [N1]
# Clase: destino · Gramática LACHO
# Destino especial que envía un mensaje a todos los nodos activos.
# destino: IDENTIFIER | BROADCAST
# IF destino == "broadcast": >> BROADCAST
# [command] :: GLOBAL_BROADCAST

## BLACKLIST [N1]
# Clase: filtro · Gramática · ledger.py
# Lista de formas verbales excluidas del sistema de validación.
# En ledger.py: filtra cristales y verbos que no cumplen el estándar.
# "Filtrar cristales que no estén en BLACKLIST"
# Ver: GREEN-KNOWLEDGE · BEHAVIORAL_RAG

